{
  "name": "@sealant/runtime-client",
  "version": "0.2.0",
  "description": "Ergonomic, typed TypeScript client for the sealantd runtime daemon.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/get-sealant/sealantd.git",
    "directory": "packages/runtime-client"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "node --test test/*.test.ts",
    "clean": "rm -rf dist",
    "lint": "oxlint .",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@sealant/runtime-protocol": "workspace:^",
    "@bufbuild/protobuf": "^2.12.0"
  }
}
